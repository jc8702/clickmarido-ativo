# ============================================
# DATABASE (PostgreSQL)
# ============================================
# Local via Docker:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/crm_db?schema=public"
# Produção (Neon):
DATABASE_URL="postgresql://[user]:[password]@[host]/[dbname]?sslmode=require"

# ============================================
# REDIS (Bull Queues)
# ============================================
# Local via Docker:
# REDIS_HOST="localhost"
# REDIS_PORT=6379
# REDIS_PASSWORD=""
# Produção (Upstash):
REDIS_HOST="us1-xxx-xxx.upstash.io"
REDIS_PORT=31393
REDIS_PASSWORD="YOUR_UPSTASH_PASSWORD"
REDIS_TLS="true"

# ============================================
# JWT AUTHENTICATION & SEED CONFIG
# ============================================
JWT_SECRET="sua-chave-secreta-muito-segura"
JWT_EXPIRATION="1d"
SEED_ADMIN_PASSWORD="sua-senha-do-admin-inicial"

# ============================================
# MERCADOPAGO
# ============================================
MP_ACCESS_TOKEN="APP_USR-xxx"
MP_PUBLIC_KEY="APP_USR-xxx"
MP_WEBHOOK_SECRET="xxx"

# ============================================
# RESEND (Emails)
# ============================================
RESEND_API_KEY="re_xxx"

# ============================================
# CLOUDINARY (Fotos)
# ============================================
CLOUDINARY_URL="cloudinary://[key]:[secret]@[cloud_name]"

# ============================================
# AI ASSISTANT (OpenRouter)
# ============================================
# Principal: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-xxx"
# Modelo de chat (verificar modelos gratuitos em openrouter.ai/models?max_price=0)
OPENROUTER_CHAT_MODEL="openrouter/free"
# Modelo de embeddings (verificar disponibilidade)
OPENROUTER_EMBEDDING_MODEL="openai/text-embedding-3-small"
# Fallback (opcional): https://kilo.ai
KILO_API_KEY=""

# ============================================
# APP CONFIG
# ============================================
PORT=3001
FRONTEND_URL="http://localhost:3000"
# FRONTEND_URL="https://seu-app.vercel.app"
