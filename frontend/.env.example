# === Banco de Dados ===
# String de conexão do Neon (PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech:5432/crm_db?sslmode=require

# === Autenticação ===
# E-mail e senha do único administrador do sistema
NEXT_PUBLIC_ADMIN_EMAIL=seu-email@example.com
ADMIN_PASSWORD=sua-senha-123
# Segredo para assinar o JWT (pode gerar um hash aleatório)
JWT_SECRET=seu-secret-aleatorio-256-bits

# === URLs ===
NEXT_PUBLIC_API_URL=http://localhost:3000

# === Integrações (Mock) ===
MERCADOPAGO_CLIENT_SECRET=seu-secret
