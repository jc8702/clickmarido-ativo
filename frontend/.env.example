# === DATABASE ===
# Obter em https://console.neon.tech
DATABASE_URL="postgresql://[user]:[password]@[host]/[dbname]?sslmode=require"

# === JWT ===
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="seu-hash-aleatorio-256-bits"

# === APPLICATION ===
# Desenvolvimento: http://localhost:3000
# Produção: https://seu-dominio.vercel.app
NEXT_PUBLIC_API_URL="http://localhost:3000"

# === GOOGLE OAUTH 2.0 (GMAIL API) ===
GOOGLE_CLIENT_ID="seu-google-client-id"
GOOGLE_CLIENT_SECRET="seu-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"
GOOGLE_GMAIL_REFRESH_TOKEN="seu-google-gmail-refresh-token"

# === AI PROVIDERS (FREE) ===
# OpenRouter - Provider principal (gratuito)
# Obter chave em: https://openrouter.ai/keys
# Modelos gratuitos: openrouter/free ou meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_API_KEY="sua-chave-openrouter"

# Kilo - Provider fallback (gratuito com rate limit)
# Funciona sem chave, mas com limite de 200 req/hora
# Obter chave em: https://kilo.ai (opcional)
KILO_API_KEY=""

