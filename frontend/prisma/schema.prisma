generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String         @db.VarChar(255)
  email         String         @unique @db.VarChar(255)
  passwordHash  String         @db.VarChar(255)
  role          String         @default("admin") @db.VarChar(20)
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  uploadedMedia Media[]
  notifications Notification[]
  leads         Lead[]
  leadEvents    LeadEvent[]

  @@map("users")
}

model Technician {
  id            String         @id @default(cuid())
  name          String         @db.VarChar(255)
  email         String         @default("") @db.VarChar(255)
  phone         String         @default("") @db.VarChar(20)
  specialty     String         @default("") @db.VarChar(100)
  active        Boolean        @default(true)

  // Dados pessoais e profissionais
  document      String         @default("") @db.VarChar(20)    // CPF
  address       String         @default("") @db.VarChar(500)
  avatarUrl     String?        @db.Text
  bio           String         @default("") @db.Text
  hourlyRate    Decimal?       @db.Decimal(10, 2)              // Valor hora/serviço
  hireDate      DateTime?                                      // Data de contratação

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  serviceOrders ServiceOrder[]
  appointments  Appointment[]
  reviews       Review[]
  nps           NPS[]
  leadAppointments LeadAppointment[]

  @@map("technicians")
}

model Customer {
  id            String         @id @default(cuid())
  name          String         @db.VarChar(255)
  email         String?        @unique @db.VarChar(255)
  phone         String         @db.VarChar(20)
  addresses     Json           @default("[]")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  quotations    Quotation[]
  warranties    Warranty[]
  payments      Payment[]
  serviceOrders ServiceOrder[]
  invoices      Invoice[]
  appointments  Appointment[]
  reviews       Review[]
  nps           NPS[]

  // Financeiro
  creditLimit  Decimal? @default(0) @db.Decimal(10, 2)
  taxDocNumber String? // CPF/CNPJ

  @@map("customers")
}

model Quotation {
  id             String          @id @default(cuid())
  number         String?         @unique @db.VarChar(30)
  customerId     String
  items          QuotationItem[]
  total          Decimal         @default(0) @db.Decimal(10, 2)
  status         String          @default("rascunho")
  temperature    String          @default("MORNO") // QUENTE, MORNO, FRIO
  notes          String          @default("")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  customer       Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  warranties     Warranty[]
  payments       Payment[]
  serviceOrder   ServiceOrder?
  invoice        Invoice?
  purchaseOrders PurchaseOrder[]

  // Financeiro
  paymentTerms      String? @default("A_VISTA") // A_VISTA, 30_DIAS, 60_DIAS
  paymentMethods    String? @default("") // Ex: "PIX, Cartão de Crédito, Boleto"
  executionDeadline String? @default("") // Ex: "5 dias úteis", "Conforme agendamento"

  // Pagamento e Margem
  paymentMethod      String?  @default("PIX") // PIX, DINHEIRO, CARTAO_CREDITO
  installments       Int?     @default(1) // 1-10 parcelas
  marginPercentage   Decimal? @default(0) @db.Decimal(5, 2) // 0-100%
  discountPercentage Decimal? @default(0) @db.Decimal(5, 2) // 0-100% Desconto

  // Automação
  expiryNotificationSent Boolean @default(false)

  // Aprovação Digital
  approvedAt          DateTime?
  approvedBy          String?  @db.VarChar(255)
  approvalIp          String?  @db.VarChar(50)
  signatureImage      String?  @db.Text

  // Dados de Origem do Lead (rastreabilidade)
  leadId              String?  // ID do lead de origem
  leadSourceChannel   String?  @db.VarChar(50) // Canal de origem: WhatsApp, Instagram, etc
  leadSourceCampaign  String?  @db.VarChar(100) // Campanha de origem
  leadPriority        String?  @default("MEDIA") // Prioridade original do lead
  leadScore           Int?     @default(0) // Score do lead no momento da qualificação
  leadIntention       String?  // Intenção original do lead
  leadQualification   String?  // Metodologia de qualificação utilizada (BANT, CHAMP, GPCT, SPIN)
  leadResponsavelId   String?  // Responsável original pelo lead

  @@index([customerId])
  @@index([leadId])
  @@map("quotations")
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  productId   String
  quantity    Decimal   @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal   @default(0) @db.Decimal(10, 2)
  costPrice   Decimal   @default(0) @db.Decimal(10, 2)
  markup      Decimal   @default(1) @db.Decimal(5, 2)
  subtotal    Decimal   @default(0) @db.Decimal(10, 2)
  notes       String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([quotationId])
  @@index([productId])
  @@map("quotation_items")
}

model Warranty {
  id                  String    @id @default(cuid())
  quotationId         String
  customerId          String
  service_description String
  expiry_date         DateTime
  createdAt           DateTime  @default(now())
  customer            Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  quotation           Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  // Automação
  reminderSent Boolean @default(false)

  @@index([quotationId])
  @@index([customerId])
  @@map("warranties")
}

model Product {
  id                 String              @id @default(cuid())
  name               String              @db.VarChar(255)
  sku                String              @unique @db.VarChar(50)
  type               String              @db.VarChar(20) // "SERVICO" ou "PECA"
  description        String              @default("")
  price              Decimal             @default(0) @db.Decimal(10, 2)
  unit               String              @default("un") @db.VarChar(10) // un, m², h, kg, etc
  category           String              @default("") @db.VarChar(100)
  active             Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  quotationItems     QuotationItem[]
  purchaseOrderItems PurchaseOrderItem[]
  productUsages      ProductUsage[]

  // Fornecedor padrão associado ao SKU
  vendorId String?
  vendor   Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  quantity      Int     @default(0) // Apenas se type == 'PECA'
  minStock      Int     @default(0) // Alerta se quantity <= minStock
  estimatedTime Int?    @default(60) // Em minutos, padrão 1h
  imageUrl      String? @db.Text

  @@index([sku])
  @@index([type])
  @@index([active])
  @@index([vendorId])
  @@map("products")
}

model ServiceOrder {
  id             String              @id @default(cuid())
  number         String              @unique @db.VarChar(20)
  quotationId    String              @unique
  customerId     String
  technicianId   String?
  scheduledTime  DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  status         String              @default("agendada") @db.VarChar(20)
  address        String              @default("") @db.VarChar(500)
  notes          String              @default("")
  finalTotal     Decimal             @default(0) @db.Decimal(10, 2)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  quotation      Quotation           @relation(fields: [quotationId], references: [id])
  customer       Customer            @relation(fields: [customerId], references: [id])
  technician     Technician?         @relation(fields: [technicianId], references: [id])
  photos         ServiceOrderPhoto[]
  purchaseOrders PurchaseOrder[]
  appointments   Appointment[]
  media          Media[]
  reviews        Review[]
  signature      SignatureRequest?
  productUsages  ProductUsage[]
  expenses       Expense[]

  // Automação
  automationLog     Json?
  notificationsSent Json?
  checklist         Json?

  nps               NPS[]

  @@index([quotationId])
  @@index([customerId])
  @@index([technicianId])
  @@index([status])
  @@map("service_orders")
}

model Payment {
  id          String     @id @default(cuid())
  quotationId String?
  customerId  String
  amount      Decimal    @default(0) @db.Decimal(10, 2)
  method      String     @default("pix") @db.VarChar(20)
  status      String     @default("pendente") @db.VarChar(20)
  pixCode     String     @default("") @db.Text
  description String     @default("")
  paidAt      DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  invoiceId   String?
  invoice     Invoice?   @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  quotation   Quotation? @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  customer    Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Mercado Pago
  mpPaymentId         String? @unique
  mpStatus            String?
  mpPaymentMethodId   String?
  mpExternalReference String?

  // Dados PIX expandidos
  pixQrCode     String?   @db.Text
  pixExpiration DateTime?

  // Dados Boleto
  boletoNumber  String?
  boletoBarcode String?
  boletoUrl     String? @db.Text

  // Dados Cartão
  cardBrand    String?
  cardLast4    String?
  installments Int?

  // Nota Fiscal
  nfeUrl    String? @db.Text
  nfeNumber String?

  // Controle
  confirmedAt DateTime?
  dueDateAt   DateTime?

  // Automação
  remindersSent   Int       @default(0)
  lastReminderAt  DateTime?
  notificationLog Json?

  @@index([quotationId])
  @@index([customerId])
  @@index([invoiceId])
  @@index([status])
  @@index([mpPaymentId])
  @@index([confirmedAt])
  @@map("payments")
}

model ServiceOrderPhoto {
  id             String       @id @default(cuid())
  serviceOrderId String
  url            String       @db.Text
  fileName       String       @default("") @db.VarChar(255)
  type           String       @default("geral") @db.VarChar(20)
  createdAt      DateTime     @default(now())
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  @@index([serviceOrderId])
  @@map("service_order_photos")
}

model Invoice {
  id String @id @default(cuid())

  // Referência
  quotationId String? @unique
  customerId  String

  // Dados da nota
  invoiceNumber String   @unique
  seriesNumber  String?  @default("1")
  issueDate     DateTime @default(now())
  dueDate       DateTime

  // Valores
  subtotal       Decimal  @default(0) @db.Decimal(10, 2)
  taxAmount      Decimal  @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal  @default(0) @db.Decimal(10, 2)
  discountAmount Decimal? @default(0) @db.Decimal(10, 2)

  // Status
  status String  @default("rascunho")
  nfeUrl String? @db.Text

  // Fiscal
  taxRegime String   @default("SIMPLES")
  issRate   Decimal? @db.Decimal(5, 2)

  // Metadados
  description String?  @default("")
  notes       String?  @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quotation Quotation? @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  customer  Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  payments  Payment[]

  @@unique([invoiceNumber, seriesNumber])
  @@index([quotationId])
  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

model Expense {
  id String @id @default(cuid())

  // Categoria
  category   String // MATERIAL, SERVICO, TRANSPORTE, ALUGUEL, UTILITIES, FERRAMENTAS, OUTROS
  costCenter String? @default("")

  // Dados
  description String  @db.VarChar(255)
  amount      Decimal @default(0) @db.Decimal(10, 2)

  // Fornecedor (opcional)
  vendorId   String?
  vendorName String? @default("")

  // Datas
  expenseDate DateTime  @default(now())
  dueDate     DateTime?
  paidAt      DateTime?

  // Status
  status String @default("pendente")

  // Documento
  documentType   String? // NOTA_FISCAL, RECIBO, OUTRO
  documentNumber String?

  // Vinculação com OS (CRÍTICO - integra com ServiceOrder)
  serviceOrderId String? // FK para ServiceOrder

  // Metadados
  notes         String?  @default("")
  attachmentUrl String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vendor         Vendor?         @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  serviceOrder   ServiceOrder?   @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  purchaseOrders PurchaseOrder[]

  @@index([category])
  @@index([costCenter])
  @@index([vendorId])
  @@index([status])
  @@index([expenseDate])
  @@index([dueDate])
  @@index([serviceOrderId])
  @@map("expenses")
}

model Vendor {
  id String @id @default(cuid())

  // Dados
  name      String  @db.VarChar(255)
  tradeName String? @default("")
  email     String? @db.VarChar(255)
  phone     String? @db.VarChar(20)
  whatsapp  String? @db.VarChar(20)

  // Fiscal
  cnpjCpf               String? @unique
  stateRegistration     String? @default("")
  municipalRegistration String? @default("")

  // Endereço
  address     String? @default("")
  contactName String? @default("")

  // Classificação e Controle
  category            String  @default("OUTROS") // MATERIAL, SERVICO, TRANSPORTE, EQUIPAMENTO, FERRAMENTAS, TERCEIRIZADO, OUTROS
  classification      String  @default("B") // A, B, C, D
  paymentTerms        String? @default("")
  averageDeliveryDays Int?    @default(0)
  isActive            Boolean @default(true)
  isBlocked           Boolean @default(false)

  // Relacionamento
  expenses       Expense[]
  purchaseOrders PurchaseOrder[]
  products       Product[]

  // Metadados
  notes     String?  @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cnpjCpf])
  @@index([isActive])
  @@index([classification])
  @@index([category])
  @@map("vendors")
}

model PurchaseOrder {
  id                   String               @id @default(cuid())
  number               String               @unique @db.VarChar(30)
  vendorId             String
  quotationId          String?
  serviceOrderId       String?
  expenseId            String?
  status               String               @default("rascunho")
  issueDate            DateTime             @default(now())
  expectedDeliveryDate DateTime?
  deliveredAt          DateTime?
  paymentTerms         String?              @default("")
  paymentMethod        String?              @default("")
  costCenter           String?              @default("")
  requestedBy          String?              @default("")
  deliveryAddress      String?              @default("")
  subtotal             Decimal              @default(0) @db.Decimal(10, 2)
  discountAmount       Decimal              @default(0) @db.Decimal(10, 2)
  freightAmount        Decimal              @default(0) @db.Decimal(10, 2)
  taxAmount            Decimal              @default(0) @db.Decimal(10, 2)
  totalAmount          Decimal              @default(0) @db.Decimal(10, 2)
  internalNotes        String?              @default("")
  supplierTerms        String?              @default("")
  attachments          Json?
  metadata             Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  vendor               Vendor               @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  quotation            Quotation?           @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  serviceOrder         ServiceOrder?        @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  expense              Expense?             @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  items                PurchaseOrderItem[]
  events               PurchaseOrderEvent[]

  @@index([vendorId])
  @@index([quotationId])
  @@index([serviceOrderId])
  @@index([expenseId])
  @@index([status])
  @@index([issueDate])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  productId        String?
  description      String        @db.VarChar(500)
  quantity         Decimal       @default(1) @db.Decimal(10, 2)
  unit             String        @default("un") @db.VarChar(20)
  unitPrice        Decimal       @default(0) @db.Decimal(10, 2)
  discountAmount   Decimal       @default(0) @db.Decimal(10, 2)
  taxAmount        Decimal       @default(0) @db.Decimal(10, 2)
  subtotal         Decimal       @default(0) @db.Decimal(10, 2)
  receivedQuantity Decimal       @default(0) @db.Decimal(10, 2)
  status           String        @default("pendente")
  notes            String?       @default("")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product          Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([purchaseOrderId])
  @@index([productId])
  @@index([status])
  @@map("purchase_order_items")
}

model PurchaseOrderEvent {
  id              String        @id @default(cuid())
  purchaseOrderId String
  type            String        @db.VarChar(50)
  description     String        @db.VarChar(500)
  oldValue        Json?
  newValue        Json?
  createdBy       String?       @db.VarChar(100)
  createdAt       DateTime      @default(now())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([type])
  @@index([createdAt])
  @@map("purchase_order_events")
}

model FinancialTransaction {
  id String @id @default(cuid())

  // Tipo
  type String // INVOICE_ISSUED, PAYMENT_RECEIVED, EXPENSE_RECORDED, ADJUSTMENT, TRANSFER

  // Referências
  invoiceId String?
  paymentId String?
  expenseId String?

  // Valores
  debit   Decimal? @default(0) @db.Decimal(10, 2)
  credit  Decimal? @default(0) @db.Decimal(10, 2)
  balance Decimal? @default(0) @db.Decimal(10, 2)

  // Descrição
  description String  @db.VarChar(500)
  notes       String? @default("")

  // Data
  transactionDate DateTime @default(now())

  // Auditoria
  userId    String?
  userEmail String?

  createdAt DateTime @default(now())

  @@index([type])
  @@index([transactionDate])
  @@index([invoiceId])
  @@index([paymentId])
  @@index([expenseId])
  @@map("financial_transactions")
}

model AccountBalance {
  id String @id @default(cuid())

  // Data do saldo
  balanceDate DateTime

  // Saldos
  opening Decimal @default(0) @db.Decimal(10, 2)
  inflow  Decimal @default(0) @db.Decimal(10, 2)
  outflow Decimal @default(0) @db.Decimal(10, 2)
  closing Decimal @default(0) @db.Decimal(10, 2)

  // Previsão
  forecast30 Decimal? @default(0) @db.Decimal(10, 2)
  forecast60 Decimal? @default(0) @db.Decimal(10, 2)
  forecast90 Decimal? @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([balanceDate])
  @@index([balanceDate])
  @@map("account_balances")
}

model AuditLog {
  id        String   @id @default(cuid())
  entity    String   @db.VarChar(50) // 'quotation', 'payment', 'service_order'
  entityId  String   @db.VarChar(100)
  action    String   @db.VarChar(100) // 'created', 'updated', 'automation_triggered'
  oldValue  Json?
  newValue  Json?
  createdAt DateTime @default(now())
  createdBy String?  @db.VarChar(100)

  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// NOVOS MÓDULOS - FASE 1
// ============================================

model Appointment {
  id String @id @default(cuid())

  // Campos
  date     DateTime
  duration Int // minutos
  status   String   @default("agendada") @db.VarChar(20) // agendada, confirmada, em_andamento, concluida, cancelada, nao_compareceu
  notes    String?  @db.Text
  location String   @db.VarChar(500)

  // Relações
  serviceOrderId String
  technicianId   String
  customerId     String

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  technician   Technician   @relation(fields: [technicianId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])

  @@unique([technicianId, date]) // Evita duplas
  @@index([serviceOrderId])
  @@index([technicianId])
  @@index([customerId])
  @@index([date])
  @@index([status])
  @@map("appointments")
}

model Media {
  id String @id @default(cuid())

  // Arquivo
  fileUrl  String @db.Text
  fileName String @db.VarChar(255)
  fileSize Int // bytes
  mimeType String @db.VarChar(50) // image/jpeg, image/png

  // Tipo
  type        String  @default("geral") @db.VarChar(20) // antes, depois, progresso, problema, solucao
  caption     String? @db.VarChar(500)
  geoLocation String? @db.VarChar(100) // latitude,longitude

  // Relações
  serviceOrderId   String
  uploadedByUserId String

  // Audit
  uploadedAt DateTime  @default(now())
  deletedAt  DateTime?

  // Relations
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  uploadedBy   User         @relation(fields: [uploadedByUserId], references: [id])

  @@index([serviceOrderId])
  @@index([uploadedByUserId])
  @@index([type])
  @@map("media")
}

model Notification {
  id String @id @default(cuid())

  // Usuário
  userId String

  // Conteúdo
  type    String @db.VarChar(50) // os_criada, os_atualizada, os_concluida, agendamento_criado, lembrete_agendamento, pagamento_recebido, pagamento_atrasado, garantia_expirando, nova_avaliacao, estoque_baixo
  title   String @db.VarChar(255)
  message String @db.Text

  // Referência
  relatedEntityId   String? @db.VarChar(100)
  relatedEntityType String? @db.VarChar(50) // service_order, payment, warranty, appointment

  // Status
  isRead Boolean   @default(false)
  readAt DateTime?

  // Canais
  sentViaEmail Boolean @default(false)
  sentViaSMS   Boolean @default(false)
  sentViaPush  Boolean @default(false)

  // Audit
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

model Review {
  id String @id @default(cuid())

  // Relações
  serviceOrderId String
  customerId     String
  technicianId   String

  // Conteúdo
  rating  Int // 1-5
  comment String? @db.Text
  photos  Json? // Array de URLs de fotos

  // Audit
  createdAt DateTime @default(now())

  // Relations
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  technician   Technician   @relation(fields: [technicianId], references: [id])

  @@unique([serviceOrderId]) // Uma review por OS
  @@index([customerId])
  @@index([technicianId])
  @@index([rating])
  @@map("reviews")
}

model NPS {
  id String @id @default(cuid())

  // Usuário
  clientId String

  // Score
  score    Int // 0-10
  feedback String? @db.Text

  // Técnico
  serviceOrderId String?
  technicianId   String?
  technicianScore Int? // 1-5

  // Audit
  createdAt DateTime @default(now())

  // Relations
  customer Customer @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  technician Technician? @relation(fields: [technicianId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([score])
  @@index([technicianId])
  @@map("nps_surveys")
}

model MessageLog {
  id        String   @id @default(cuid())
  phone     String   @db.VarChar(20)
  template  String   @db.VarChar(50)
  status    String   @db.VarChar(20) // SENT, FAILED
  error     String?  @db.Text
  variables Json
  createdAt DateTime @default(now())

  @@map("message_logs")
}

model SignatureRequest {
  id             String       @id @default(cuid())
  serviceOrderId String       @unique
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  signatureData  String       @db.Text // Canvas drawing em Data URI (Base64)
  signerName     String       @db.VarChar(255)
  signedAt       DateTime     @default(now())
  ipAddress      String?      @db.VarChar(50)
  userAgent      String?      @db.VarChar(255)
  createdAt      DateTime     @default(now())

  @@map("signature_requests")
}

model ProductUsage {
  id             String       @id @default(cuid())
  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantityUsed   Decimal      @default(1) @db.Decimal(10, 2)
  createdAt      DateTime     @default(now())

  @@index([serviceOrderId])
  @@index([productId])
  @@map("product_usages")
}

model CompanySettings {
  id                    String   @id @default(cuid())
  companyName           String   @default("Click Marido") @db.VarChar(255)
  cnpj                  String?  @db.VarChar(20)
  phone                 String?  @db.VarChar(20)
  email                 String?  @db.VarChar(255)
  address               String?  @db.VarChar(500)
  defaultHourlyRate     Decimal  @default(80.0) @db.Decimal(10, 2)
  defaultWarranty       String   @default("90 dias nos termos do art. 26, II do CDC.") @db.Text
  defaultCommissionRate Decimal  @default(40.0) @db.Decimal(10, 2)
  logoUrl               String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("company_settings")
}

// ==========================================
// WHATSAPP - FAVORITOS, ARQUIVAMENTO, ETIQUETAS
// ==========================================

model WhatsAppFavorite {
  id        String   @id @default(cuid())
  phone     String   @db.VarChar(20)
  userId    String
  createdAt DateTime @default(now())

  @@unique([phone, userId])
  @@index([userId])
  @@map("whatsapp_favorites")
}

model WhatsAppArchived {
  id         String   @id @default(cuid())
  phone      String   @db.VarChar(20)
  userId     String
  archivedAt DateTime @default(now())

  @@unique([phone, userId])
  @@index([userId])
  @@map("whatsapp_archived")
}

model WhatsAppLabel {
  id     String @id @default(cuid())
  name   String @db.VarChar(50)
  color  String @default("#00a884") @db.VarChar(20)
  userId String

  conversations WhatsAppConversationLabel[]

  @@unique([name, userId])
  @@index([userId])
  @@map("whatsapp_labels")
}

model WhatsAppConversationLabel {
  id      String        @id @default(cuid())
  phone   String        @db.VarChar(20)
  labelId String
  label   WhatsAppLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)
  userId  String

  @@unique([phone, labelId, userId])
  @@index([labelId])
  @@index([userId])
  @@map("whatsapp_conversation_labels")
}

enum LeadStatus {
  FRIO
  MORNO
  QUENTE
  URGENTE
  PRONTO_ORCAMENTO
}

enum LeadFunnelStage {
  NOVO_LEAD
  EM_TRIAGEM
  QUALIFICADO
  EM_FOLLOWUP
  AGENDADO
  ENCAMINHADO_ORCAMENTO
  DESCARTADO
  SEM_CONTATO
  EM_CONTATO
  CONTATO_REALIZADO
  LEAD_QUALIFICADO
  LEAD_NAO_QUALIFICADO
  REUNIAO_AGENDADA
  COMPARECEU
  PROPOSTA_SOLICITADA
  PROPOSTA_ENVIADA
  EM_NEGOCIACAO
  GANHO
  PERDIDO
  SEM_RESPOSTA
  REATIVADO
}

enum LeadQualificationStage {
  QUALIFICADO
  PARCIALMENTE_QUALIFICADO
  EM_VALIDACAO
  DESQUALIFICADO
  SEM_VALIDACAO
}

enum LeadIntention {
  PESQUISANDO
  COMPARANDO
  PRONTO_PARA_ORCAMENTO
  PRONTO_PARA_FECHAMENTO
  ACOMPANHAR_DEPOIS
}

enum LeadNextAction {
  LIGAR
  RESPONDER_WHATSAPP
  ENVIAR_PROPOSTA
  AGENDAR_VISITA
  AGENDAR_REUNIAO
  PEDIR_MAIS_INFORMACOES
  NUTRIR_LEAD
  ENCAMINHAR_ORCAMENTO
  DESCARTAR
}

enum LeadLossReason {
  SEM_ORCAMENTO
  SEM_TIMING
  SEM_NECESSIDADE
  SEM_AUTORIDADE
  FORA_DE_PERFIL
  CONCORRENCIA
  RETORNO_FUTURO
  CONTATO_INVALIDO
}

enum LeadPriority {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum LeadEventType {
  LEAD_CREATED
  LEAD_UPDATED
  LEAD_ORIGIN_ASSIGNED
  LEAD_OWNER_ASSIGNED
  LEAD_CONTACTED
  LEAD_QUALIFIED
  LEAD_DISQUALIFIED
  APPOINTMENT_SCHEDULED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_CONFIRMED
  APPOINTMENT_MISSED
  PROPOSAL_REQUESTED
  PROPOSAL_SENT
  PROPOSAL_VIEWED
  FOLLOWUP_LOGGED
  STAGE_CHANGED
  DEAL_WON
  DEAL_LOST
  LOST_REASON_DEFINED
  SLA_BREACHED
  LEAD_REACTIVATED
}

enum AppointmentStatus {
  AGENDADO
  REAGENDADO
  CONFIRMADO
  FALTOU
  REALIZADO
}

model LeadSource {
  id          String   @id @default(cuid())
  channel     String   @db.VarChar(50) // WhatsApp, Instagram, Google Ads, Indicação, etc
  campaign    String?  @db.VarChar(100)
  subcampaign String?  @db.VarChar(100)
  keyword     String?  @db.VarChar(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  leads       Lead[]

  @@map("lead_sources")
}

model Lead {
  id                String             @id @default(cuid())
  name              String             @db.VarChar(255)
  email             String?            @db.VarChar(255)
  phone             String?            @db.VarChar(20)
  sourceId          String?
  source            LeadSource?        @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  responsavelId     String?
  responsavel       User?              @relation(fields: [responsavelId], references: [id], onDelete: SetNull)
  customerId        String?            @db.VarChar(255)
  quotationId       String?            @db.VarChar(255)
  status            LeadStatus         @default(FRIO)
  funnelStage       LeadFunnelStage    @default(NOVO_LEAD)
  score             Int                @default(0)
  lossReason        LeadLossReason?
  lossNotes         String?            @db.Text
  firstResponseTime DateTime?
  slaBreachCount    Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  events            LeadEvent[]
  appointments      LeadAppointment[]
  alerts            OperationalAlert[]

  // CRM Avançado - Classificações
  priority           LeadPriority       @default(MEDIA)
  estimatedValue     Decimal?           @db.Decimal(10, 2)
  qualificationStage LeadQualificationStage @default(SEM_VALIDACAO)
  intention          LeadIntention?
  nextAction         LeadNextAction?
  prioritizationMethod String?
  qualificationData  Json?
  tags               String?

  // Rastreamento de Cadência e SLA
  lastContactAt      DateTime?
  nextFollowupAt     DateTime?
  cadenceCount       Int                @default(0)
  cadenceInterval    Int?               // intervalo em horas entre follow-ups
  riskAlert          String?            @db.Text
  riskAlertLevel     String?            // BAIXO, MEDIO, ALTO, CRITICO

  // Dados BANT (Budget, Authority, Need, Timing)
  bantBudget         String?            // sim, nao, em_analise, indefinido
  bantAuthority      String?            // decisor, influenciador, nao_identificado
  bantNeed           String?            // critico, importante, nice_to_have, sem_necessidade
  bantTiming         String?            // imediato, 1_3_meses, 3_6_meses, acima_6_meses, indefinido

  // Dados CHAMP (Challenge, Authority, Money, Prioritization)
  champChallenge     String?            // critico, importante, moderado, sem_desafio
  champMoney         String?            // disponivel, aprovado, em_analise, sem_orcamento
  champPriority      String?            // urgente, alta, media, baixa

  @@index([sourceId])
  @@index([responsavelId])
  @@index([funnelStage])
  @@map("leads")
}

model LeadEvent {
  id        String        @id @default(cuid())
  leadId    String
  lead      Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      LeadEventType
  oldValue  String?       @db.Text
  newValue  String?       @db.Text
  userId    String?
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  notes     String?       @db.Text
  createdAt DateTime      @default(now())

  @@index([leadId])
  @@index([type])
  @@index([createdAt])
  @@map("lead_events")
}

model LeadAppointment {
  id           String            @id @default(cuid())
  leadId       String
  lead         Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  scheduledAt  DateTime
  status       AppointmentStatus @default(AGENDADO)
  notes        String?           @db.Text
  technicianId String?
  technician   Technician?       @relation(fields: [technicianId], references: [id], onDelete: SetNull)
  googleEventId String?           @db.VarChar(255)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([leadId])
  @@index([technicianId])
  @@map("lead_appointments")
}

model OperationalAlert {
  id         String    @id @default(cuid())
  leadId     String
  lead       Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type       String    @db.VarChar(50)
  message    String    @db.Text
  resolved   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([leadId])
  @@map("operational_alerts")
}
