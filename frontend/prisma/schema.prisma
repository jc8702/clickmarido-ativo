generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String   @db.VarChar(255)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.VarChar(255)
  role         String   @default("admin") @db.VarChar(20)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  uploadedMedia Media[]
  notifications Notification[]

  @@map("users")
}

model Technician {
  id         String   @id @default(cuid())
  name       String   @db.VarChar(255)
  email      String   @default("") @db.VarChar(255)
  phone      String   @default("") @db.VarChar(20)
  specialty  String   @default("") @db.VarChar(100)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  serviceOrders ServiceOrder[]
  appointments   Appointment[]
  reviews        Review[]

  @@map("technicians")
}

model Customer {
  id         String      @id @default(cuid())
  name       String      @db.VarChar(255)
  email      String?     @unique @db.VarChar(255)
  phone      String      @db.VarChar(20)
  addresses  Json        @default("[]")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  quotations Quotation[]
  warranties Warranty[]
  payments   Payment[]
  serviceOrders ServiceOrder[]
  invoices   Invoice[]
  appointments Appointment[]
  reviews    Review[]
  nps        NPS[]

  // Financeiro
  creditLimit       Float?    @default(0)
  taxDocNumber      String?   // CPF/CNPJ

  @@map("customers")
}

model Quotation {
  id           String             @id @default(cuid())
  customerId   String
  items        QuotationItem[]
  total        Float              @default(0)
  status       String             @default("rascunho")
  notes        String             @default("")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  customer     Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  warranties   Warranty[]
  payments     Payment[]
  serviceOrder ServiceOrder?
  invoice      Invoice?
  purchaseOrders PurchaseOrder[]

  // Financeiro
  paymentTerms String?   @default("A_VISTA")  // A_VISTA, 30_DIAS, 60_DIAS

  // Automação
  expiryNotificationSent Boolean @default(false)

  @@index([customerId])
  @@map("quotations")
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  productId   String
  quantity    Float     @default(1)
  unitPrice   Float     @default(0)
  subtotal    Float     @default(0)
  notes       String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([quotationId])
  @@index([productId])
  @@map("quotation_items")
}

model Warranty {
  id                  String    @id @default(cuid())
  quotationId         String
  customerId          String
  service_description String
  expiry_date         DateTime
  createdAt           DateTime  @default(now())
  customer            Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  quotation           Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  // Automação
  reminderSent        Boolean   @default(false)

  @@index([quotationId])
  @@index([customerId])
  @@map("warranties")
}

model Product {
  id              String            @id @default(cuid())
  name            String            @db.VarChar(255)
  sku             String            @unique @db.VarChar(50)
  type            String            @db.VarChar(20) // "SERVICO" ou "PECA"
  description     String            @default("")
  price           Float             @default(0)
  unit            String            @default("un") @db.VarChar(10) // un, m², h, kg, etc
  category        String            @default("") @db.VarChar(100)
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  quotationItems  QuotationItem[]
  purchaseOrderItems PurchaseOrderItem[]

  // Fornecedor padrão associado ao SKU
  vendorId        String?
  vendor          Vendor?           @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([sku])
  @@index([type])
  @@index([active])
  @@index([vendorId])
  @@map("products")
}

model ServiceOrder {
  id             String            @id @default(cuid())
  number         String            @unique @db.VarChar(20)
  quotationId    String            @unique
  customerId     String
  technicianId   String?
  scheduledTime  DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  status         String            @default("agendada") @db.VarChar(20)
  address        String            @default("") @db.VarChar(500)
  notes          String            @default("")
  finalTotal     Float             @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  quotation      Quotation         @relation(fields: [quotationId], references: [id])
  customer       Customer          @relation(fields: [customerId], references: [id])
  technician     Technician?       @relation(fields: [technicianId], references: [id])
  photos         ServiceOrderPhoto[]
  purchaseOrders PurchaseOrder[]
  appointments   Appointment[]
  media          Media[]
  reviews        Review[]

  // Automação
  automationLog     Json?
  notificationsSent Json?

  @@index([quotationId])
  @@index([customerId])
  @@index([technicianId])
  @@index([status])
  @@map("service_orders")
}

model Payment {
  id                String    @id @default(cuid())
  quotationId       String?
  customerId        String
  amount            Float     @default(0)
  method            String    @default("pix") @db.VarChar(20)
  status            String    @default("pendente") @db.VarChar(20)
  pixCode           String    @default("") @db.Text
  description       String    @default("")
  paidAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  invoiceId         String?
  invoice           Invoice?   @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  quotation         Quotation? @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  customer          Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Mercado Pago
  mpPaymentId       String?   @unique
  mpStatus          String?
  mpPaymentMethodId String?
  mpExternalReference String?

  // Dados PIX expandidos
  pixQrCode         String?   @db.Text
  pixExpiration     DateTime?

  // Dados Boleto
  boletoNumber      String?
  boletoBarcode     String?
  boletoUrl         String?   @db.Text

  // Dados Cartão
  cardBrand         String?
  cardLast4         String?
  installments      Int?

  // Nota Fiscal
  nfeUrl            String?   @db.Text
  nfeNumber         String?

  // Controle
  confirmedAt       DateTime?
  dueDateAt         DateTime?

  // Automação
  remindersSent     Int       @default(0)
  lastReminderAt    DateTime?
  notificationLog   Json?

  @@index([quotationId])
  @@index([customerId])
  @@index([invoiceId])
  @@index([status])
  @@index([mpPaymentId])
  @@index([confirmedAt])
  @@map("payments")
}

model ServiceOrderPhoto {
  id             String        @id @default(cuid())
  serviceOrderId String
  url            String        @db.Text
  fileName       String        @default("") @db.VarChar(255)
  type           String        @default("geral") @db.VarChar(20)
  createdAt      DateTime      @default(now())
  serviceOrder   ServiceOrder  @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  @@index([serviceOrderId])
  @@map("service_order_photos")
}

model Invoice {
  id                String    @id @default(cuid())

  // Referência
  quotationId       String    @unique
  customerId        String

  // Dados da nota
  invoiceNumber     String    @unique
  seriesNumber      String?   @default("1")
  issueDate         DateTime  @default(now())
  dueDate           DateTime

  // Valores
  subtotal          Float     @default(0)
  taxAmount         Float     @default(0)
  totalAmount       Float     @default(0)
  discountAmount    Float?    @default(0)

  // Status
  status            String    @default("rascunho")
  nfeUrl            String?   @db.Text

  // Fiscal
  taxRegime         String    @default("SIMPLES")
  issRate           Float?

  // Metadados
  description       String?   @default("")
  notes             String?   @default("")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  quotation         Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  customer          Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  payments          Payment[]

  @@unique([invoiceNumber, seriesNumber])
  @@index([quotationId])
  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

model Expense {
  id                String    @id @default(cuid())

  // Categoria
  category          String    // MATERIAL, SERVICO, TRANSPORTE, ALUGUEL, UTILITIES, FERRAMENTAS, OUTROS
  costCenter        String?   @default("")

  // Dados
  description       String    @db.VarChar(255)
  amount            Float     @default(0)

  // Fornecedor (opcional)
  vendorId          String?
  vendorName        String?   @default("")

  // Datas
  expenseDate       DateTime  @default(now())
  dueDate           DateTime?
  paidAt            DateTime?

  // Status
  status            String    @default("pendente")

  // Documento
  documentType      String?   // NOTA_FISCAL, RECIBO, OUTRO
  documentNumber    String?

  // Vinculação com OS (CRÍTICO - integra com ServiceOrder)
  serviceOrderId    String?   // FK para ServiceOrder

  // Metadados
  notes             String?   @default("")
  attachmentUrl     String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  vendor            Vendor?   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  purchaseOrders    PurchaseOrder[]

  @@index([category])
  @@index([costCenter])
  @@index([vendorId])
  @@index([status])
  @@index([expenseDate])
  @@index([dueDate])
  @@index([serviceOrderId])
  @@map("expenses")
}

model Vendor {
  id                String    @id @default(cuid())

  // Dados
  name              String    @db.VarChar(255)
  tradeName         String?   @default("")
  email             String?   @db.VarChar(255)
  phone             String?   @db.VarChar(20)
  whatsapp          String?   @db.VarChar(20)

  // Fiscal
  cnpjCpf           String?   @unique
  stateRegistration String?   @default("")
  municipalRegistration String? @default("")

  // Endereço
  address           String?   @default("")
  contactName       String?   @default("")

  // Classificação e Controle
  category          String    @default("OUTROS") // MATERIAL, SERVICO, TRANSPORTE, EQUIPAMENTO, FERRAMENTAS, TERCEIRIZADO, OUTROS
  classification    String    @default("B") // A, B, C, D
  paymentTerms      String?   @default("")
  averageDeliveryDays Int?    @default(0)
  isActive          Boolean   @default(true)
  isBlocked         Boolean   @default(false)

  // Relacionamento
  expenses          Expense[]
  purchaseOrders    PurchaseOrder[]
  products          Product[]

  // Metadados
  notes             String?   @default("")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([cnpjCpf])
  @@index([isActive])
  @@index([classification])
  @@index([category])
  @@map("vendors")
}

model PurchaseOrder {
  id                   String               @id @default(cuid())
  number               String               @unique @db.VarChar(30)
  vendorId             String
  quotationId          String?
  serviceOrderId       String?
  expenseId            String?
  status               String               @default("rascunho")
  issueDate            DateTime             @default(now())
  expectedDeliveryDate DateTime?
  deliveredAt          DateTime?
  paymentTerms         String?              @default("")
  paymentMethod        String?              @default("")
  costCenter           String?              @default("")
  requestedBy          String?              @default("")
  deliveryAddress      String?              @default("")
  subtotal             Float                @default(0)
  discountAmount       Float                @default(0)
  freightAmount        Float                @default(0)
  taxAmount            Float                @default(0)
  totalAmount          Float                @default(0)
  internalNotes        String?              @default("")
  supplierTerms        String?              @default("")
  attachments          Json?
  metadata             Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  vendor               Vendor               @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  quotation            Quotation?           @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  serviceOrder         ServiceOrder?        @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  expense              Expense?             @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  items                PurchaseOrderItem[]
  events               PurchaseOrderEvent[]

  @@index([vendorId])
  @@index([quotationId])
  @@index([serviceOrderId])
  @@index([expenseId])
  @@index([status])
  @@index([issueDate])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  productId        String?
  description      String        @db.VarChar(500)
  quantity         Float         @default(1)
  unit             String        @default("un") @db.VarChar(20)
  unitPrice        Float         @default(0)
  discountAmount   Float         @default(0)
  taxAmount        Float         @default(0)
  subtotal         Float         @default(0)
  receivedQuantity Float         @default(0)
  status           String        @default("pendente")
  notes            String?       @default("")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product          Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([purchaseOrderId])
  @@index([productId])
  @@index([status])
  @@map("purchase_order_items")
}

model PurchaseOrderEvent {
  id              String        @id @default(cuid())
  purchaseOrderId String
  type            String        @db.VarChar(50)
  description     String        @db.VarChar(500)
  oldValue        Json?
  newValue        Json?
  createdBy       String?       @db.VarChar(100)
  createdAt       DateTime      @default(now())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([type])
  @@index([createdAt])
  @@map("purchase_order_events")
}

model FinancialTransaction {
  id                String    @id @default(cuid())

  // Tipo
  type              String    // INVOICE_ISSUED, PAYMENT_RECEIVED, EXPENSE_RECORDED, ADJUSTMENT, TRANSFER

  // Referências
  invoiceId         String?
  paymentId         String?
  expenseId         String?

  // Valores
  debit             Float?    @default(0)
  credit            Float?    @default(0)
  balance           Float?    @default(0)

  // Descrição
  description       String    @db.VarChar(500)
  notes             String?   @default("")

  // Data
  transactionDate   DateTime  @default(now())

  // Auditoria
  userId            String?
  userEmail         String?

  createdAt         DateTime  @default(now())

  @@index([type])
  @@index([transactionDate])
  @@index([invoiceId])
  @@index([paymentId])
  @@index([expenseId])
  @@map("financial_transactions")
}

model AccountBalance {
  id                String    @id @default(cuid())

  // Data do saldo
  balanceDate       DateTime

  // Saldos
  opening           Float     @default(0)
  inflow            Float     @default(0)
  outflow           Float     @default(0)
  closing           Float     @default(0)

  // Previsão
  forecast30        Float?    @default(0)
  forecast60        Float?    @default(0)
  forecast90        Float?    @default(0)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([balanceDate])
  @@index([balanceDate])
  @@map("account_balances")
}

model AuditLog {
  id        String   @id @default(cuid())
  entity    String   @db.VarChar(50)    // 'quotation', 'payment', 'service_order'
  entityId  String   @db.VarChar(100)
  action    String   @db.VarChar(100)   // 'created', 'updated', 'automation_triggered'
  oldValue  Json?
  newValue  Json?
  createdAt DateTime @default(now())
  createdBy String?  @db.VarChar(100)

  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// NOVOS MÓDULOS - FASE 1
// ============================================

model Appointment {
  id             String   @id @default(cuid())
  
  // Campos
  date           DateTime
  duration       Int      // minutos
  status         String   @default("agendada") @db.VarChar(20) // agendada, confirmada, em_andamento, concluida, cancelada, nao_compareceu
  notes          String?  @db.Text
  location       String   @db.VarChar(500)
  
  // Relações
  serviceOrderId String
  technicianId   String
  customerId     String
  
  // Audit
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Relations
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  technician     Technician   @relation(fields: [technicianId], references: [id])
  customer       Customer     @relation(fields: [customerId], references: [id])
  
  @@unique([technicianId, date]) // Evita duplas
  @@index([serviceOrderId])
  @@index([technicianId])
  @@index([customerId])
  @@index([date])
  @@index([status])
  @@map("appointments")
}

model Media {
  id             String   @id @default(cuid())
  
  // Arquivo
  fileUrl        String   @db.Text
  fileName       String   @db.VarChar(255)
  fileSize       Int      // bytes
  mimeType       String   @db.VarChar(50) // image/jpeg, image/png
  
  // Tipo
  type           String   @default("geral") @db.VarChar(20) // antes, depois, progresso, problema, solucao
  caption        String?  @db.VarChar(500)
  geoLocation    String?  @db.VarChar(100) // latitude,longitude
  
  // Relações
  serviceOrderId String
  uploadedByUserId String
  
  // Audit
  uploadedAt     DateTime @default(now())
  deletedAt      DateTime?
  
  // Relations
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  uploadedBy     User         @relation(fields: [uploadedByUserId], references: [id])
  
  @@index([serviceOrderId])
  @@index([uploadedByUserId])
  @@index([type])
  @@map("media")
}

model Notification {
  id               String   @id @default(cuid())
  
  // Usuário
  userId           String
  
  // Conteúdo
  type             String   @db.VarChar(50) // os_criada, os_atualizada, os_concluida, agendamento_criado, lembrete_agendamento, pagamento_recebido, pagamento_atrasado, garantia_expirando, nova_avaliacao, estoque_baixo
  title            String   @db.VarChar(255)
  message          String   @db.Text
  
  // Referência
  relatedEntityId  String?  @db.VarChar(100)
  relatedEntityType String? @db.VarChar(50) // service_order, payment, warranty, appointment
  
  // Status
  isRead           Boolean  @default(false)
  readAt           DateTime?
  
  // Canais
  sentViaEmail     Boolean  @default(false)
  sentViaSMS       Boolean  @default(false)
  sentViaPush      Boolean  @default(false)
  
  // Audit
  createdAt        DateTime @default(now())
  
  // Relations
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, isRead])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

model Review {
  id             String   @id @default(cuid())
  
  // Relações
  serviceOrderId String
  customerId     String
  technicianId   String
  
  // Conteúdo
  rating         Int      // 1-5
  comment        String?  @db.Text
  photos         Json?    // Array de URLs de fotos
  
  // Audit
  createdAt      DateTime @default(now())
  
  // Relations
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  customer       Customer     @relation(fields: [customerId], references: [id])
  technician     Technician   @relation(fields: [technicianId], references: [id])
  
  @@unique([serviceOrderId]) // Uma review por OS
  @@index([customerId])
  @@index([technicianId])
  @@index([rating])
  @@map("reviews")
}

model NPS {
  id        String   @id @default(cuid())
  
  // Usuário
  clientId  String
  
  // Score
  score     Int      // 0-10
  feedback  String?  @db.Text
  
  // Audit
  createdAt DateTime @default(now())
  
  // Relations
  customer  Customer @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  @@index([clientId])
  @@index([score])
  @@map("nps_surveys")
}
