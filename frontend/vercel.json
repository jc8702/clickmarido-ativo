{
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "devCommand": "npm run dev",
  "crons": [
    {
      "path": "/api/cron/payment-reminders",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/warranty-expiry-check",
      "schedule": "0 09 * * *"
    },
    {
      "path": "/api/cron/quotation-expiry-check",
      "schedule": "0 08 * * *"
    },
    {
      "path": "/api/cron/daily-report",
      "schedule": "0 18 * * *"
    }
  ]
}
